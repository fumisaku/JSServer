## Visual Studio / VB.NET 用 .gitignore

# Visual Studio キャッシュ・一時ファイル
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates
*.userprefs

# ビルド成果物
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/

# NuGet
*.nupkg
**/packages/*
!**/packages/build/
*.nuget.props
*.nuget.targets

# ログファイル
*.log

# 一時ファイル
~$*
*~
*.tmp
*.tmp_proj

# Visual Studio プロファイラ
*.psess
*.vsp
*.vspx

# テスト結果
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
TestResult.xml

# その他
*.pdb
*.ilk
*.meta
*.obj
*.pch
*.pgc
*.pgd
*.rsp
*.sbr
*.tlb
*.tli
*.tlh
*.vspscc
*.vssscc
*.pidb
*.svclog
*.scc
*.[Cc]ache
!*.[Cc]ache/
*.dbmdl
*.pfx
node_modules/