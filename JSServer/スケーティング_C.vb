'入力用パラメータ
Public Class ORG_スケーティング

    Public Property ジャッジ人数 As Integer
    Public Property ジャッジ過半数 As Integer

    Public ジャッジ記号() As String


    Public Property 選手数 As Integer

    Public ORG_スケーティング_選手素点() As ORG_スケーティング_選手素点

    '再スケーティング用





    Public Sub New(選手数_, ジャッジ人数_)

        選手数 = 選手数_
        ジャッジ人数 = ジャッジ人数_

        ReDim ORG_スケーティング_選手素点(選手数)
        For s = 1 To 選手数
            ORG_スケーティング_選手素点(s) = New ORG_スケーティング_選手素点(ジャッジ人数)
        Next

        ReDim ジャッジ記号(ジャッジ人数)

    End Sub


End Class


